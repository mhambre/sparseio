    {
      "id": "K1ShhtT-6Ih9t417V8LoX",
      "type": "text",
      "x": 618.5952323404947,
      "y": 321.49999999999994,
      "width": 330.8095353190107,
      "height": 145.05555555555563,
      "angle": 0,
      "strokeColor": "#f08c00",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
