        }
      ],
      "updated": 1780193660322,
      "link": null,
      "locked": false,
      "text": "Annual Operations Review\n\nThis report provides a comprehensive overview of organizational activities\nconducted during the reporting period.\nThe purpose of this document is to record major developments, summarize\nobserved outcomes,\nidentify areas requiring further attention, and establish a consistent reference\npoint for future planning efforts.\nInformation contained herein has been compiled from internal records,\ndepartmental submissions,\nand management reviews.\nAll findings should be interpreted within the context of the reporting period\nand may be subject to revision as additional information becomes available.\n",
      "fontSize": 8.288888888888893,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Annual Operations Review\n\nThis report provides a comprehensive overview of organizational activities conducted during the reporting period.\nThe purpose of this document is to record major developments, summarize observed outcomes,\nidentify areas requiring further attention, and establish a consistent reference point for future planning efforts.\nInformation contained herein has been compiled from internal records, departmental submissions,\nand management reviews.\nAll findings should be interpreted within the context of the reporting period\nand may be subject to revision as additional information becomes available.\n",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "8MBGfGgGKj4tYBwmkeSuq",
      "type": "text",
      "x": 1128.5952323404942,
      "y": 575.4999999999998,
      "width": 330.8095353190107,
      "height": 103.61111111111116,
      "angle": 0,
      "strokeColor": "#846358",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
