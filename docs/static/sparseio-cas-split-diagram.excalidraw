      "isDeleted": false,
      "boundElements": [
        {
          "id": "VdbtCm2Rw2IqSmAZM84bq",
          "type": "arrow"
        }
      ],
      "updated": 1780193641967,
      "link": null,
      "locked": false,
      "text": "The contents of this report are intended solely for documentation,\nanalysis, and strategic planning purposes.\nReaders should consider the information presented as a snapshot of conditions\nand activities during the specified period.\nAny decisions based on this material should take into account subsequent\ndevelopments,\nupdated assessments, and additional supporting documentation.\nDistribution of this report should follow applicable organizational policies\ngoverning internal records and information management.\n",
      "fontSize": 8.288888888888893,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The contents of this report are intended solely for documentation,\nanalysis, and strategic planning purposes.\nReaders should consider the information presented as a snapshot of conditions\nand activities during the specified period.\nAny decisions based on this material should take into account subsequent developments,\nupdated assessments, and additional supporting documentation.\nDistribution of this report should follow applicable organizational policies\ngoverning internal records and information management.\n",
      "autoResize": false,
      "lineHeight": 1.25
    },
